# Last EHR — environment configuration
# Copy to `.env.local` for local dev (`.env.local` is gitignored).
# For self-hosting, the only required values are a FHIR backend + one model key.

# ── FHIR backend (Medplum) ──────────────────────────────────────────────
# Point at your own Medplum instance, or leave unset to use Medplum's hosted
# API (https://api.medplum.com/). For a fully local backend, run Medplum and
# set this to e.g. http://localhost:8103/.
NEXT_PUBLIC_MEDPLUM_BASE_URL=
MEDPLUM_BASE_URL=

# ── AI model (bring your own key) ───────────────────────────────────────
# Provider for the chat agent. "openai" (default) or "anthropic".
AI_PROVIDER=openai
# Optional model override (e.g. gpt-4.1-mini, claude-sonnet-4-6).
MODEL_ID=
# Set the key matching AI_PROVIDER:
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Sign-in (Medplum Google OAuth) ──────────────────────────────────────
# The demo sign-in uses Medplum's Google OAuth. Needed for the gated /demo
# sign-in flow.
NEXT_PUBLIC_MEDPLUM_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_AUTH_ORIGINS=

# ── Quickstart (no OAuth client needed) ─────────────────────────────────
# Start the /demo without Google sign-in, using a Medplum ClientApplication's
# client credentials (server-side). For local / self-host eval on synthetic
# data only. Set NEXT_PUBLIC_QUICKSTART=true and provide both credentials.
NEXT_PUBLIC_QUICKSTART=
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# ── Optional: rate limiting (Upstash Redis) ─────────────────────────────
# Recommended for a public demo. On Vercel, serverless instances don't share
# memory, so reliable per-IP limits need a shared store. Create a free Upstash
# Redis (https://upstash.com) and set both values; without them the app falls
# back to a best-effort in-memory limiter (fine for local dev). Limits are
# tunable via RATE_LIMIT_PER_IP_MAX (default 10/min) and RATE_LIMIT_GLOBAL_MAX
# (default 200/min).
#
# The Vercel Marketplace Upstash integration provisions KV_REST_API_URL +
# KV_REST_API_TOKEN automatically — the app reads those too, so on Vercel you
# usually don't need to set anything here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_PER_IP_MAX=10
# RATE_LIMIT_GLOBAL_MAX=200

# ── Optional: analytics (PostHog) ───────────────────────────────────────
# Leave unset to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Optional: lastehr.com only ──────────────────────────────────────────
# Powers the marketing-site waitlist (Neon Postgres). Self-hosters don't
# need this — the marketing pages are specific to lastehr.com.
DATABASE_URL=
# POSTGRES_URL=
