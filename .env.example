# Last EHR environment configuration
# Copy to `.env.local` for local dev (`.env.local` is gitignored).
# For self-hosting you need a FHIR backend plus either a model key or the
# explicitly limited local scripted demo below. The published MCP package
# connects to Medplum only; `npm run mcp:demo` is a separate synthetic local
# evaluation lab that needs no environment variables.
# For the fastest zero-key walkthrough after `npm install`, run
# `npm run demo:local`; it supplies the scripted local settings without reading
# or modifying this file.

# ── FHIR backend selection ──────────────────────────────────────────────
# FHIR_BACKEND=medplum (default) talks to Medplum with the settings below.
# FHIR_BACKEND=hapi talks to a FHIR R4 server at FHIR_BASE_URL with no
# credentials. The included Docker stack is for local, single-tenant synthetic
# evaluation only; session isolation is client-side filtering, not auth.
# FHIR_BACKEND=
# FHIR_BASE_URL=http://localhost:8080/fhir

# Copy-ready ZERO-KEY local HAPI walkthrough (uncomment all six values):
# This is not an LLM: it makes no model-provider request, always searches the
# seeded Maria Garcia record, and can only propose one 72 bpm observation.
# It is locked to a local HAPI URL and synthetic data; never use it as a real
# agent or point it at a non-local server.
# FHIR_BACKEND=hapi
# FHIR_BASE_URL=http://localhost:8080/fhir
# NEXT_PUBLIC_QUICKSTART=true
# AI_PROVIDER=scripted
# LASTEHR_SCRIPTED_DEMO=true
# NEXT_PUBLIC_SCRIPTED_DEMO=true

# ── FHIR backend (Medplum) ──────────────────────────────────────────────
# Point at your own Medplum instance, or leave unset to use Medplum's hosted
# API (https://api.medplum.com/). For a fully local backend, run Medplum and
# set this to e.g. http://localhost:8103/.
NEXT_PUBLIC_MEDPLUM_BASE_URL=
MEDPLUM_BASE_URL=

# ── AI model (bring your own key for a real agent) ──────────────────────
# Provider policy: only BAA-capable providers ship here, because deployments
# head toward real clinical data (the demo stays synthetic-only). OpenAI and
# Anthropic both sign BAAs with zero-retention options for API traffic on
# qualifying plans; signing one is YOUR step, not a default. Aggregators that
# cannot sign a BAA (e.g. OpenRouter) are deliberately not offered. A
# multi-model BAA-capable path via AWS Bedrock is included.
#   openai     (default)  OPENAI_API_KEY,     MODEL_ID e.g. gpt-4.1-mini
#   anthropic             ANTHROPIC_API_KEY,  MODEL_ID e.g. claude-sonnet-4-6
#   bedrock    AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY + AWS_REGION;
#              MODEL_ID REQUIRED (region-prefixed inference profile, e.g.
#              us.anthropic.claude-haiku-4-5-20251001-v1:0). One AWS BAA
#              covers several model families (Anthropic, Meta, Mistral).
#   scripted   NO KEY. An explicit, fixed, local HAPI synthetic walkthrough;
#              it requires LASTEHR_SCRIPTED_DEMO=true and is not an LLM.
# Whatever you pick must support TOOL CALLING or the agent cannot work.
# `scripted` cannot be combined with Medplum or a remote FHIR URL. To use a
# real agent with HAPI, leave LASTEHR_SCRIPTED_DEMO unset and configure one of
# the external providers below instead.
# AI_PROVIDER=
# Optional model override; provider default used when unset.
# MODEL_ID=
# Set the key matching AI_PROVIDER:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Optional demo model picker: comma-separated "model-id|Label" pairs shown as
# a dropdown in the demo. Ids must be servable by YOUR configured provider
# and key (one key serves several models). The server honors only ids on this
# list; anything else falls back to MODEL_ID. Inlined at BUILD time (changing
# it requires a rebuild). Sanity-check with: npm run check:models
# NEXT_PUBLIC_DEMO_MODELS=gpt-4.1-mini|GPT-4.1 mini,gpt-5-mini|GPT-5 mini

# ── Sign-in (Medplum Google OAuth) ──────────────────────────────────────
# The demo sign-in uses Medplum's Google OAuth. Needed for the gated /demo
# sign-in flow.
NEXT_PUBLIC_MEDPLUM_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_AUTH_ORIGINS=

# ── SMART App Launch (open Last EHR from the Medplum app) ───────────────
# Register a ClientApplication in your Medplum project with
#   launchUri    = https://<your-deploy>/launch
#   redirectUri  = https://<your-deploy>/launch/callback
# and set its id here. Last EHR then appears on the Apps tab of every
# Patient and Encounter page in app.medplum.com; launching opens the chat
# scoped to that patient, reusing the Medplum sign-in (no separate login).
# Public client with PKCE; no client secret is used. The default scopes are
# least-privilege and compartment the session to the launched patient; override
# with SMART_SCOPES if you want broader access (e.g. user/*.*).
SMART_CLIENT_ID=
# SMART_SCOPES=

# ── Quickstart (no OAuth client needed) ─────────────────────────────────
# Start the Medplum-backed /demo without Google sign-in using a
# ClientApplication's client credentials (server-side). The HAPI local web
# demo only needs NEXT_PUBLIC_QUICKSTART=true; it does not use these values.
# NEXT_PUBLIC_QUICKSTART=
# Set only with AI_PROVIDER=scripted for the local HAPI walkthrough above.
# This public value changes the UI disclosure and is inlined at build time, so
# restart `npm run dev` or rebuild Docker after changing it.
# NEXT_PUBLIC_SCRIPTED_DEMO=
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# ── Optional: read-only MCP server (npm run mcp) ─────────────────────────
# `npm run mcp` builds and starts @lastehr/mcp. It exposes exactly two
# chart-reading tools over stdio: search_patients and show_patient_info.
# Auth reuses MEDPLUM_CLIENT_ID + MEDPLUM_CLIENT_SECRET above (or
# MEDPLUM_ACCESS_TOKEN). There is no MCP write flag in the 0.1.x package.
# Read access can still return PHI: use a least-privilege Medplum identity.
#
# For a checkout-only synthetic HAPI MCP lab instead, run `npm run mcp:demo`.
# It does not read these Medplum variables, only permits the repository fixture
# patients, and is never a PHI or production path. Your MCP client still uses
# its own model account for synthetic tool results.

# ── Optional: rate limiting (Upstash Redis) ─────────────────────────────
# Recommended for a public demo. On Vercel, serverless instances don't share
# memory, so reliable per-IP limits need a shared store. Create a free Upstash
# Redis (https://upstash.com) and set both values; without them the app falls
# back to a best-effort in-memory limiter (fine for local dev). Limits are
# tunable via RATE_LIMIT_PER_IP_MAX (default 10/min) and RATE_LIMIT_GLOBAL_MAX
# (default 200/min).
#
# The Vercel Marketplace Upstash integration provisions KV_REST_API_URL +
# KV_REST_API_TOKEN automatically; the app reads those too, so on Vercel you
# usually don't need to set anything here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_PER_IP_MAX=10
# RATE_LIMIT_GLOBAL_MAX=200

# ── Optional: analytics (PostHog) ───────────────────────────────────────
# Leave unset to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Optional: lastehr.com only ──────────────────────────────────────────
# Powers the marketing-site waitlist (Neon Postgres). Self-hosters don't
# need this; the marketing pages are specific to lastehr.com.
DATABASE_URL=
# POSTGRES_URL=
