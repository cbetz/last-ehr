{
  "name": "last-ehr",
  "version": "0.2.1",
  "private": true,
  "description": "Open-source AI agent layer for Medplum / FHIR: a permissioned AI agent over the chart.",
  "license": "Apache-2.0",
  "author": "Chris Betz",
  "homepage": "https://www.lastehr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/cbetz/last-ehr.git"
  },
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run mcp:build && next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "mcp": "npm run mcp:build && node packages/mcp/dist/cli.js",
    "mcp:build": "npm run build --workspace=@lastehr/mcp",
    "mcp:pack:check": "npm pack --workspace=@lastehr/mcp --dry-run",
    "mcp:demo": "tsx scripts/mcp-demo.ts",
    "eval": "tsx scripts/eval.ts",
    "eval:hapi": "tsx scripts/eval.ts --no-prepare",
    "fhir:wait": "tsx scripts/wait-for-fhir.ts",
    "demo:local": "tsx scripts/demo-local.ts",
    "demo:local:prepare": "tsx scripts/demo-local.ts --prepare",
    "demo:local:down": "docker compose down",
    "check:models": "tsx scripts/check-models.ts",
    "docker:local": "docker compose --env-file .env.local -f docker-compose.yml -f docker-compose.app.yml up --build",
    "docker:local:down": "docker compose --env-file .env.local -f docker-compose.yml -f docker-compose.app.yml down",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.105",
    "@ai-sdk/anthropic": "^3.0.90",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/react": "^3.0.195",
    "@medplum/core": "5.1.13",
    "@medplum/fhirtypes": "5.1.13",
    "@medplum/react-hooks": "5.1.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.16.0",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.376.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
